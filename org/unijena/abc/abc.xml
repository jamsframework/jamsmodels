<model name="abc model" author="D. Boyle and P. Krause" date="18.05.2006">
    <!--compoundcomponent class="org.unijena.jams.tools.JAMSParaSampler" name="Sampler">
        <var name="parameterIDs" value="abcModel.a;abcModel.b"/>
