<?xml version='1.0' encoding='utf-8'?>

<!--<!DOCTYPE JAMSModel SYSTEM "jamsmodel.dtd">-->

<model name="The Thornthwaite model" author="S. Markstrom (?)" date="30.09.2005">

    <component class="gov.usgs.thornthwaite.EntityProvider" name="EntityProvider">
        <jamsvar class="org.unijena.jams.data.JAMSString" name="fileName" value="d:/jamsmodels/Thornthwaite/data/entities.dat"/>
    </component>

    <compoundcomponent class="org.unijena.jams.model.JAMSTemporalContext" name="TemporalContext">
        <jamsvar class="org.unijena.jams.data.JAMSTimeInterval" name="timeInterval" value="1960-01-01 00:01 1990-12-01 00:00 2 1"/>

        <component class="gov.usgs.thornthwaite.Climate" name="ClimateReader">
            <jamsvar class="org.unijena.jams.data.JAMSString" name="fileName" value="d:/jamsmodels/Thornthwaite/data/thorn.dat"/>
        </component>

        <compoundcomponent class="org.unijena.jams.model.JAMSSpatialContext" name="SpatialContext">
            <jamsvar class="org.unijena.jams.data.JAMSEntityCollection" name="entities" provider="EntityProvider" providervar="entities"/>           

		        <component class="gov.usgs.thornthwaite.EntityUnpacker" name="EntityUnpacker">
								<jamsvar class="org.unijena.jams.data.JAMSEntity" name="entity" provider="SpatialContext" providervar="currentEntity"/>
		        </component>        
		
		        <component class="gov.usgs.thornthwaite.Daylen" name="Daylen">
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="latitude" provider="EntityUnpacker" providervar="latitude"/>
		            <jamsvar class="org.unijena.jams.data.JAMSCalendar" name="time" provider="TemporalContext" providervar="current"/>
		        </component>
		            
		        <component class="gov.usgs.thornthwaite.HamonET" name="HamonET">
		            <jamsvar class="org.unijena.jams.data.JAMSCalendar" name="time" provider="TemporalContext" providervar="current"/>
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="temp" provider="ClimateReader" providervar="temp"/>
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="daylength" provider="Daylen" providervar="daylength"/>
		        </component>
		        
		        <component class="gov.usgs.thornthwaite.SoilMoisture" name="SoilMoisture">
								<jamsvar class="org.unijena.jams.data.JAMSDouble" name="soilMoistStorCap" provider="EntityUnpacker" providervar="soilMoistStorCap"/>
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="potET" provider="HamonET" providervar="potET"/>
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="temp" provider="ClimateReader" providervar="temp"/>
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="precip" provider="ClimateReader" providervar="precip"/>
								<jamsvar class="org.unijena.jams.data.JAMSDouble" name="prestor" provider="EntityUnpacker" providervar="prestor"/>		            
		        </component>
		        
		        <component class="gov.usgs.thornthwaite.Snow" name="Snow">
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="snowStorage" provider="EntityUnpacker" providervar="snowStorage"/>
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="potET" provider="HamonET" providervar="potET"/>
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="temp" provider="ClimateReader" providervar="temp"/>
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="precip" provider="ClimateReader" providervar="precip"/>
		        </component>
		        
		        <component class="gov.usgs.thornthwaite.Runoff" name="Runoff">
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="runoffFactor" provider="EntityUnpacker" providervar="runoffFactor"/>
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="snowMelt" provider="Snow" providervar="snowMelt"/>
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="surfaceRunoff" provider="SoilMoisture" providervar="surfaceRunoff"/>
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="remain" provider="EntityUnpacker" providervar="remain"/>
		        </component>
		        
		        <component class="gov.usgs.thornthwaite.Output" name="Output">
		            <jamsvar class="org.unijena.jams.data.JAMSString" name="fileName" value="d:/jamsmodels/Thornthwaite/data/thorn.out"/>
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="daylength" provider="Daylen" providervar="daylength"/>
		            <jamsvar class="org.unijena.jams.data.JAMSCalendar" name="time" provider="TemporalContext" providervar="current"/>
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="potET" provider="HamonET" providervar="potET"/>
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="runoff" provider="Runoff" providervar="runoff"/>
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="snowMelt" provider="Snow" providervar="snowMelt"/>
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="soilMoistStor" provider="SoilMoisture" providervar="soilMoistStor"/>
		        </component>
		        
		        <component class="gov.usgs.thornthwaite.EntityPacker" name="EntityPacker">
								<jamsvar class="org.unijena.jams.data.JAMSEntity" name="entity" provider="SpatialContext" providervar="currentEntity"/>
		            <jamsvar class="org.unijena.jams.data.JAMSDouble" name="snowStorage" provider="Snow" providervar="snowStorage"/>								
								<jamsvar class="org.unijena.jams.data.JAMSDouble" name="prestor" provider="SoilMoisture" providervar="prestor"/>		            
								<jamsvar class="org.unijena.jams.data.JAMSDouble" name="remain" provider="Runoff" providervar="remain"/>		            
		        </component>        
	        

        </compoundcomponent>

    </compoundcomponent>
    
</model>
